#para abrir arquivo xlsx - VIA 2020, 2021 e 2022
VIA <- read_xlsx("~/Documents/GitHub/dissertacao/analise/dados/VIA_geral_202122.xlsx")

#para limpar os nomes das colunas
VIA <- VIA %>%
  janitor::clean_names()

# Usando a funĂ§Ă£o pivot_longer() para multiplicar as linhas do arquivo de casos
VIA_long <- VIA %>%
  pivot_longer(cols = c(ano2020, ano2021, ano2022), names_to = "Ano", values_to = "VIA")

#renomear a coluna para ficar igual Ă  do outro arquivo
names(VIA_long)[names(VIA_long) == "dist_adm"] <- "dist_adm_da"


##### Chamando arquivo de populaĂ§Ă£o ########

pop_proj <- read_xlsx("~/Documents/GitHub/dissertacao/analise/dados/Pop_projetada_202122.xlsx")

#para limpar os nomes das colunas
pop_proj <- pop_proj %>%
  janitor::clean_names()

#para ver os nomes das colunas
names(pop_proj)

##############################################

# Usando a funĂ§Ă£o pivot_longer() para multiplicar as linhas do arquivo de populaĂ§Ă£o
pop_proj_long <- pop_proj %>%
  pivot_longer(cols = starts_with("ano"), names_to = "Ano", values_to = "pop")

#renomear a coluna para ficar igual Ă  do outro arquivo
names(pop_proj_long)[names(pop_proj_long) == "da"] <- "dist_adm_da"


# Colunas que serĂ£o usadas para a junĂ§Ă£o
CJ_VIA <- c("da", "Ano")
CJ_Pop <- c("dist_adm_da", "Ano")

# Usando a funĂ§Ă£o merge() para unir os dataframes
uniao_VIA_pop <- merge(VIA_long, pop_proj_long, by.x = CJ_VIA, by.y = CJ_Pop, all = TRUE)

#para verificar se a coluna tem algum valor NA
is.na(uniao_VIA_pop$VIA)

#para substituir o valor NA por zero
uniao_VIA_pop$VIA <- replace(uniao_VIA_pop$VIA, is.na(uniao_VIA_pop$VIA), 0)


#para excluir a coluna 'total'
uniao_VIA_pop <- uniao_VIA_pop %>% 
  dplyr::select(-total)


dados_combinados <- uniao_VIA_pop %>%
  group_by(da) %>% 
  summarise(VIA = sum(VIA),
            Pop = sum(pop))


#PadronizaĂ§Ă£o

E <- expected(
  population = dados_combinados$Pop,
  cases = dados_combinados$VIA, n.strata = 1
)

d_combinado <- group_by(dados_combinados, dist_adm_da) %>% 
  summarize(Y = sum(VIA))

d_combinado$E <- E[match(d_combinado$dist_adm_da, unique(dados_combinados$dist_adm_da))]

d_combinado$TIP <- d_combinado$Y / d_combinado$E


