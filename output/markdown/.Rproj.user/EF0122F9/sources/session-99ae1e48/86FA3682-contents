load('~/Downloads/southkorea_covid19.RData')
library(gwzinbr)
golden = Golden(data = southkorea_covid19,
       formula = n_covid1 ~ Morbidity + high_sch_p + Healthcare_access + diff_sd + Crowding + Migration + Health_behavior,
       xvarinf = "Healthcare_access",
       long = "x", 
       lat = "y", 
       offset = "ln_total", 
       model = "zinb", 
       method = "adaptive_bsq", 
       bandwidth = "aic", 
       globalmin = FALSE, 
       distancekm = TRUE, 
       force = TRUE)


modelo = gwzinbr(data = southkorea_covid19,
                 formula = n_covid1 ~ Morbidity + high_sch_p + Healthcare_access + diff_sd + Crowding + Migration + Health_behavior,
                 xvarinf = c("Morbidity","high_sch_p","Healthcare_access", "diff_sd"),
                 long = "x", 
                 lat = "y", 
                 offset = "ln_total",
                 method = "adaptive_bsq", 
                 model = "zinb", 
                 distancekm = TRUE,
                 h = 82, 
                 force = TRUE)

modelo
