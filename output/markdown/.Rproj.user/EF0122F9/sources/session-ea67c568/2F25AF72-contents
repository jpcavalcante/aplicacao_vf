```{r}
library(knitr)
library(kableExtra)
library(dplyr)

# --------- PARTE DE CONTAGEM ---------
# Estimativas modelo global
gwr_global <- as.data.frame(t(modelo_gwzinbr_global$descript_stats_gwr_param_estimates))
gwr_global$Variável <- rownames(gwr_global)

# Estimativas modelo sem covariáveis na parte zero
gwr_0 <- as.data.frame(t(modelo_gwzinbr_0$descript_stats_gwr_param_estimates))
gwr_0$Variável <- rownames(gwr_0)

# Renomeia colunas
gwr_global <- gwr_global %>% select(Variável, Mean) %>%
  rename(`GWZINBR (Zero com Covariáveis)` = Mean)

gwr_0 <- gwr_0 %>% select(Variável, Mean) %>%
  rename(`GWZINBR (Zero Constante)` = Mean)

# Junta as duas tabelas
ordem_variaveis <- c("Intercept", "Healthcare_access", "Migration", "Health_behavior","alpha")

df_contagem <- merge(gwr_global, gwr_0, by = "Variável", all = TRUE)
df_contagem <- df_contagem %>%
  mutate(Variável = factor(Variável, levels = ordem_variaveis)) %>%
  arrange(Variável)
df_alpha <- df_contagem %>% filter(Variável == "alpha") # separa alpha
df_contagem <- df_contagem %>% filter(Variável != "alpha")

# --------- PARTE DE INFLAÇÃO ---------
# Extrai estimativas da parte inflacionada dos dois modelos
zinf_global <- modelo_gwzinbr_global$descript_stats_gwr_zero_infl_param_estimates[1, ]
zinf_0 <- modelo_gwzinbr_0$descript_stats_gwr_zero_infl_param_estimates[1, ]

# Cria dataframe para inflação de zeros
df_zero <- data.frame(
  Variável = names(zinf_global),
  `GWZINBR (Zero com Covariáveis)` = round(as.numeric(zinf_global), 4),
  `GWZINBR (Zero Constante)` = c(round(as.numeric(zinf_0), 4), rep(NA, length(zinf_global) - 1)),
  stringsAsFactors = FALSE
)
# --------- Corrige nomes das colunas antes de unir ---------

# Corrige os nomes de df_zero para bater com df_contagem
colnames(df_zero) <- c("Variável", "GWZINBR (Zero com Covariáveis)", "GWZINBR (Zero Constante)")

# Adiciona coluna Parte em cada dataframe
df_contagem <- df_contagem %>%
  mutate(Parte = "")

df_zero <- df_zero %>%
  mutate(Parte = "")

# Junta as tabelas corretamente


tabela_completa <- bind_rows(df_contagem, df_zero) %>%
  select(Parte, Variável, `GWZINBR (Zero Constante)`, `GWZINBR (Zero com Covariáveis)`)

# Remove rownames
rownames(tabela_completa) <- NULL

# --------- Exibe tabela final com formatação correta ---------

colnames(tabela_completa) <- c("Variável", "Parte", "", "")

# Gera a tabela
kable(tabela_completa, align = "llrr", booktabs = TRUE,
      caption = "Comparação dos coeficientes entre modelos GWZINBR com e sem covariáveis na parte de zeros") %>%
  add_header_above(c(" " = 2,
                     "GWZINBR (Zero Constante)" = 1,
                     "GWZINBR (Zero com Covariáveis)" = 1)) %>%
  kable_styling(full_width = FALSE) %>%
  pack_rows("Parte de Contagem (Binomial Negativa)", 1, nrow(df_contagem)) %>%
  pack_rows("Parte de Inflação de Zeros (Logístico)", nrow(df_contagem) + 1, nrow(tabela_completa))


# --------- ALPHA EM TABELA SEPARADA ---------
