## GWZINBR com largura de banda grande e glm.nb (ambos sem inflação de zeros)
### Comparacao dos parametros estimados

```{r echo=FALSE, message=FALSE, warning=FALSE}
library(knitr)
library(kableExtra)
alpha_glm <- 1 / modelo_nb$theta


tabela_glm <- data.frame(
  Variável = names(global_nb),
  `GLM NB` = round(global_nb, 4),
  stringsAsFactors = FALSE
)


# Estatísticas GWZINBR
tabela_gwr <- as.data.frame(t(modelo_gwzinbr$descript_stats_gwr_param_estimates))
tabela_gwr <- round(tabela_gwr, 4)
tabela_gwr$Variável <- rownames(tabela_gwr)

# Padroniza nomes
tabela_gwr$Variável[tabela_gwr$Variável == "Intercept"] <- "(Intercept)"

# Seleciona e renomeia colunas
tabela_gwr <- tabela_gwr[, c("Variável", "Mean", "Min", "Max")]
colnames(tabela_gwr) <- c("Variável", "Média", "Mínimo", "Máximo")

tabela_gwr2 = tabela_gwr %>% filter(Variável != 'alpha')

# Junta as tabelas
tabela_final <- merge(tabela_glm, tabela_gwr2, by = "Variável", all = TRUE)

# Gera a tabela com cabeçalho mesclado e espaçamento
kable(tabela_final, align = 'lrrrr', booktabs = TRUE, caption = "Comparação das estimativas dos modelos GLM NB e GWZINBR") %>%
  add_header_above(c(" " = 2, "GWZINBR" = 3)) %>%
  column_spec(1, width = "5cm") %>%
  column_spec(2, width = "2.5cm") %>%
  column_spec(3:5, width = "3cm")

alpha_gwr = tabela_gwr %>% filter(Variável == 'alpha')
tabela_alpha<- cbind(data.frame(`GLM NB` = round(alpha_glm, 4)), data.frame('GWZINBR' = alpha_gwr[,2]))
kable(tabela_alpha, align = "lr", booktabs = TRUE,
      caption = "Estimativas do parâmetro de superdispersão (alpha)") %>%
  kable_styling(full_width = FALSE)

```
 
## zeroinfl (glm com inflação de zeros)
### Utiizando pacote zeroinfl da library pscl
#### Comparando modelo com e sem parametros na parte inflacionada 

```{r echo=FALSE, message=FALSE, warning=FALSE}
library(pscl)
library(knitr)
library(kableExtra)

modelo_zinb_const <- zeroinfl(
  n_covid1 ~ Healthcare_access + Migration + Health_behavior + offset(ln_total)|1,
  data = southkorea_covid19,
  dist = "negbin"
)

modelo_zinb_covars <- zeroinfl(
  n_covid1 ~ Healthcare_access + Migration + Health_behavior + offset(ln_total) |
    Healthcare_access + Migration + Health_behavior,
  data = southkorea_covid19,
  dist = "negbin"
)

# Extrai os coeficientes dos dois modelos
s_covars <- coef(summary(modelo_zinb_covars))
s_const  <- coef(summary(modelo_zinb_const))

# Constrói os data frames com os componentes "count" e "zero"
df_count <- merge(
  data.frame(
    Parte = "Contagem",
    Variável = rownames(s_const$count),
    Estimate_Const = round(s_const$count[, "Estimate"], 4),
    SE_Const = round(s_const$count[, "Std. Error"], 4),
    P_Const = signif(s_const$count[, "Pr(>|z|)"], 3)
  ),
  data.frame(
    Variável = rownames(s_covars$count),
    Estimate_Covars = round(s_covars$count[, "Estimate"], 4),
    SE_Covars = round(s_covars$count[, "Std. Error"], 4),
    P_Covars = signif(s_covars$count[, "Pr(>|z|)"], 3)
  ),
  by = "Variável", all = TRUE
)
df_count$Parte <- ""

df_count = df_count %>% filter(Variável != 'Log(theta)')

df_zero <- merge(
  data.frame(
    Parte = "",
    Variável = rownames(s_const$zero),
    Estimate_Const = round(s_const$zero[, "Estimate"], 4),
    SE_Const = round(s_const$zero[, "Std. Error"], 4),
    P_Const = signif(s_const$zero[, "Pr(>|z|)"], 3)
  ),
  data.frame(
    Variável = rownames(s_covars$zero),
    Estimate_Covars = round(s_covars$zero[, "Estimate"], 4),
    SE_Covars = round(s_covars$zero[, "Std. Error"], 4),
    P_Covars = signif(s_covars$zero[, "Pr(>|z|)"], 3)
  ),
  by = "Variável", all = TRUE
)
df_zero$Parte <- ""

# Junta os dois dataframes
tabela <- rbind(df_count, df_zero)
tabela <- tabela[, c("Parte", "Variável",
                     "Estimate_Const", "SE_Const", "P_Const",
                     "Estimate_Covars", "SE_Covars", "P_Covars")]

# Gera a tabela formatada
kable(tabela, align = "llrrrrrr", booktabs = TRUE,
      caption = "Comparação dos coeficientes entre modelos ZINB com e sem covariáveis na parte de zeros") %>%
  add_header_above(c(" " = 2,
                     "ZINB (Zero Constante)" = 3,
                     "ZINB (Zero com Covariáveis)" = 3)) %>%
  kable_styling(full_width = FALSE) %>%
  pack_rows("Parte de Contagem (Binomial Negativa)", 1, nrow(df_count)) %>%
  pack_rows("Parte de Inflação de Zeros (Logístico)", nrow(df_count) + 1, nrow(tabela))

# Estimação de alpha (com base no log(theta))
alpha_const  <- 1 / (modelo_zinb_const$theta)
alpha_covars <- 1 / (modelo_zinb_covars$theta)

# Tabela separada para alpha
df_alpha <- data.frame(
  Modelo = c("ZINB (Zero Constante)", "ZINB (Zero com Covariáveis)"),
  'alpha' = round(c(alpha_const, alpha_covars), 4)
)

kable(df_alpha, align = "lr", booktabs = TRUE,
      caption = "Estimativas do parâmetro de superdispersão (alpha)") %>%
  kable_styling(full_width = FALSE)

```

